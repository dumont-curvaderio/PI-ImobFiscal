# ─── ImobFiscal — Variáveis de Ambiente ──────────────────────────────────────
# Copiar para .env e preencher valores.
# NUNCA commitar .env com valores reais.

# ─── Identidade do ambiente ───────────────────────────────────────────────────
APP_ENV=development
# Valores válidos: development | staging | beta | production

# ─── SEFAZ — CRÍTICO: nunca misturar ambientes ────────────────────────────────
# Em dev/beta: SEMPRE homologacao
# Em produção: SEMPRE producao (só via CI/CD)
SEFAZ_AMBIENTE=homologacao
SEFAZ_URL=https://hom.nfe.fazenda.gov.br

# ─── Feature flags fiscais (2026) ─────────────────────────────────────────────
# FLAG_IBS_CBS_RECOLHIMENTO=false em 2026 (recolhimento dispensado)
# Mudar para true a partir de jan/2027 (CBS plena)
FLAG_IBS_CBS_RECOLHIMENTO=false
# FLAG_DIMOB_TRANSMISSAO=false até ir para produção
FLAG_DIMOB_TRANSMISSAO=false

# ─── Banco (Supabase) ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=                           # chave anon do projeto local
SUPABASE_SERVICE_ROLE_KEY=                   # NUNCA expor no frontend

# Para ambiente web (Next.js — prefixo NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Focus NFe (NF-e) ─────────────────────────────────────────────────────────
FOCUSNFE_TOKEN=                              # token sandbox gratuito
FOCUSNFE_URL=https://homologacao.focusnfe.com.br/v2

# ─── Asaas (boleto + PIX) ─────────────────────────────────────────────────────
ASAAS_TOKEN=                                 # token sandbox
ASAAS_URL=https://sandbox.asaas.com/api/v3

# ─── Clicksign (assinatura eletrônica) ───────────────────────────────────────
CLICKSIGN_API_KEY=
CLICKSIGN_URL=https://sandbox.clicksign.com/api/v1

# ─── Resend (e-mail transacional) ─────────────────────────────────────────────
RESEND_API_KEY=                              # 3.000/mês grátis no free tier

# ─── IA (análise GED) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                           # Claude Haiku — análise de docs
GOOGLE_AI_API_KEY=                           # Gemini Flash — OCR de documentos

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
JWT_SECRET=                                  # mínimo 32 chars aleatórios
NODE_ENV=development
